<dialog class="rounded-2xl p-0 shadow-2xl backdrop:bg-gray-900/40 w-[90vw] max-w-[18rem]"
        data-timesheet-target="entryDialog" data-action="click->timesheet#backdropClose">
  <div class="relative p-5">
    <%= render "close_button" %>
    <h2 class="text-sm font-semibold text-gray-900" data-timesheet-target="entryProjectName"></h2>
    <p class="text-xs text-gray-400 mb-4" data-timesheet-target="entryLabel"></p>

    <%= form_with url: time_entries_path, data: { timesheet_target: "entryForm" } do %>
      <input type="hidden" name="start" value="<%= params[:start] %>">
      <input type="hidden" name="project_id" data-timesheet-target="entryProjectId">
      <input type="hidden" name="date" data-timesheet-target="entryDate">

      <div class="grid grid-cols-3 gap-2 mb-2">
        <% [2, 4, 8].each do |quick| %>
          <button type="button" data-action="timesheet#setQuickHours" data-hours="<%= quick %>"
                  class="py-2.5 text-sm font-medium rounded-xl border border-gray-200 hover:bg-gray-900 hover:text-white hover:border-gray-900 transition-colors tabular-nums">
            <%= quick %>h
          </button>
        <% end %>
      </div>

      <div class="flex gap-2 mb-4">
        <input type="number" name="hours" step="0.5" min="0" max="24" placeholder="Custom"
               data-timesheet-target="entryHours"
               class="flex-1 w-full text-sm px-3 py-2 rounded-xl border border-gray-200 focus:border-gray-900 focus:ring-2 focus:ring-gray-900/10 focus:outline-none tabular-nums">
        <button type="submit"
                class="text-sm px-4 py-2 rounded-xl bg-gray-900 text-white hover:bg-gray-700 transition-colors">
          Set
        </button>
      </div>

      <div class="flex justify-between items-center border-t border-gray-100 pt-3">
        <button type="button" data-action="timesheet#clearEntry" data-timesheet-target="entryClear"
                class="text-xs text-gray-400 hover:text-red-500 transition-colors">
          Clear entry
        </button>
        <button type="button" data-action="timesheet#closeDialogs"
                class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
          Cancel
        </button>
      </div>
    <% end %>
  </div>
</dialog>
