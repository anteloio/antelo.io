<dialog class="rounded-2xl p-0 shadow-2xl backdrop:bg-gray-900/40 w-[90vw] max-w-md"
        data-timesheet-target="locationsDialog" data-action="click->timesheet#backdropClose">
  <div class="relative p-6">
    <%= render "close_button" %>
    <h2 class="text-base font-semibold text-gray-900 mb-4">Manage locations</h2>

    <% if @locations.empty? %>
      <p class="text-sm text-gray-400 mb-4">No locations yet. Add your first one below.</p>
    <% else %>
      <div class="flex flex-col gap-2 mb-4">
        <% @locations.each do |location| %>
          <div class="flex items-center gap-2">
            <%= form_with url: location_path(location), method: :patch,
                  class: "flex-1", data: { keep_open: "locationsDialog" } do %>
              <input type="hidden" name="start" value="<%= params[:start] %>">
              <input type="text" name="location[name]" value="<%= location.name %>" required
                     data-action="blur->timesheet#submitOnBlur"
                     class="w-full min-w-0 text-sm px-3 py-2 rounded-xl border border-gray-200 focus:border-gray-900 focus:ring-2 focus:ring-gray-900/10 focus:outline-none">
            <% end %>
            <% count = @location_counts[location.id] || 0 %>
            <% message = count == 0 ? "Delete this location?" : count == 1 ? "Delete this location? It is set on 1 day." : "Delete this location? It is set on #{count} days." %>
            <%= button_to "×", location_path(location, start: params[:start].presence),
                  method: :delete,
                  form: { data: { turbo_confirm: message } },
                  aria: { label: "Delete #{location.name}" },
                  class: "w-9 h-9 inline-flex items-center justify-center rounded-xl border border-gray-200 text-gray-400 hover:bg-red-50 hover:text-red-500 hover:border-red-200 transition-colors flex-shrink-0" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= form_with url: locations_path, class: "flex items-center gap-2 border-t border-gray-100 pt-4",
          data: { keep_open: "locationsDialog" } do %>
      <input type="hidden" name="start" value="<%= params[:start] %>">
      <input type="text" name="location[name]" placeholder="New location name" required
             class="flex-1 min-w-0 text-sm px-3 py-2 rounded-xl border border-gray-200 focus:border-gray-900 focus:ring-2 focus:ring-gray-900/10 focus:outline-none">
      <button type="submit"
              class="text-sm px-4 py-2 rounded-xl bg-gray-900 text-white hover:bg-gray-700 transition-colors flex-shrink-0">
        Add
      </button>
    <% end %>
  </div>
</dialog>
