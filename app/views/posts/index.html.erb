<% content_for :title, "Posts · Flavio Antelo" %>
<% content_for :description, "Thoughts on software, agent loops, and building businesses." %>

<section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
  <h1 class="text-2xl font-semibold text-gray-900 mb-2">Posts</h1>
  <p class="text-gray-500 mb-16">Thoughts on software, agent loops, and building businesses.</p>

  <% if @posts.empty? %>
    <div class="text-center py-20 text-gray-400">
      <p class="text-sm">Posts coming soon.</p>
    </div>
  <% else %>
    <div class="grid gap-8">
      <% @posts.each do |post| %>
        <a href="<%= post_path(post.id) %>" class="group block">
          <p class="text-xs text-gray-400 mb-1"><%= post.published_at.strftime("%B %-d, %Y") %></p>
          <h2 class="text-lg font-medium text-gray-900 group-hover:text-gray-600 transition-colors mb-1">
            <%= post.title %>
          </h2>
          <p class="text-sm text-gray-500 leading-relaxed"><%= post.description %></p>
        </a>
      <% end %>
    </div>
  <% end %>
</section>
