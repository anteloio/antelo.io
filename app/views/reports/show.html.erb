<% content_for :title, "Monthly report · Flavio Antelo" %>
<% content_for :description, "Monthly timesheet report." %>
<% content_for :noindex, true %>
<% content_for :hide_footer, true %>
<% content_for :wide, true %>

<section class="max-w-5xl mx-auto px-6 pt-16 pb-24" style="font-feature-settings: 'cv02' 1, 'tnum' 1;">
  <!-- Back link -->
  <div class="flex items-center justify-between gap-3 mb-6 text-xs text-gray-400">
    <a href="<%= timesheet_path %>" class="inline-flex items-center gap-1.5 hover:text-gray-900 transition-colors">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
      </svg>
      Back to timesheet
    </a>
    <span class="truncate max-w-[16rem]"><%= current_user.email %></span>
  </div>

  <!-- Header -->
  <div class="flex items-end justify-between flex-wrap gap-6 mb-8">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-gray-900">Monthly report</h1>
      <p class="text-sm text-gray-500 mt-1">Total hours per project</p>
    </div>
    <div class="text-right">
      <div class="text-3xl font-semibold tabular-nums text-gray-900 leading-none">
        <%= fmt_hours(@total_hours) %><span class="text-base font-normal text-gray-400 ml-0.5">h</span>
      </div>
      <div class="text-sm font-medium text-gray-500 tabular-nums mt-1.5 <%= "invisible" unless @total_value > 0 %>">
        <%= @total_value > 0 ? fmt_money(@total_value) : "-" %>
      </div>
      <div class="text-xs text-gray-400 mt-1 uppercase tracking-wide"><%= @month.label_full.downcase %></div>
    </div>
  </div>

  <!-- Month navigation -->
  <div class="flex items-center gap-2 mb-4">
    <div class="inline-flex items-center h-9 rounded-lg border border-gray-300 overflow-hidden divide-x divide-gray-300">
      <a href="<%= report_path(month: @month.prev_key) %>" aria-label="Previous month"
         class="w-9 h-full inline-flex items-center justify-center text-lg text-gray-500 hover:bg-gray-50 transition-colors">‹</a>
      <a href="<%= report_path(month: @month.next_key) %>" aria-label="Next month"
         class="w-9 h-full inline-flex items-center justify-center text-lg text-gray-500 hover:bg-gray-50 transition-colors">›</a>
    </div>
    <div class="inline-flex items-center h-9 px-4 rounded-lg border border-gray-300 bg-white text-sm text-gray-700">
      <span class="font-medium tabular-nums"><%= @month.label %></span>
    </div>
    <% unless @month.current? %>
      <a href="<%= report_path %>"
         class="h-9 px-3 inline-flex items-center rounded-lg border border-gray-300 bg-white text-sm text-gray-600 hover:bg-gray-50 transition-colors">This month</a>
    <% end %>
  </div>

  <!-- Table -->
  <% if @report.empty? %>
    <div class="rounded-2xl border border-dashed border-gray-200 bg-gray-50/50 py-20 text-center">
      <p class="text-sm text-gray-500">No hours logged in <%= @month.label_full %>.</p>
      <p class="text-xs text-gray-400 mt-1">Log some time on the timesheet to see it here.</p>
    </div>
  <% else %>
    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-gray-50/70 border-b border-gray-200">
              <th class="text-left font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-5 min-w-[150px]">Project</th>
              <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-4 w-20">Days</th>
              <% if @has_any_rate %>
                <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-4 w-24">Rate</th>
              <% end %>
              <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-4 w-24">Hours</th>
              <% if @has_any_rate %>
                <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-5 w-28">Value</th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @report.each do |row| %>
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50/60 transition-colors">
                <td class="py-3 px-5 align-middle whitespace-nowrap text-gray-900 font-medium"><%= row[:name] %></td>
                <td class="py-3 px-4 text-right align-middle tabular-nums text-gray-500"><%= row[:days] %></td>
                <% if @has_any_rate %>
                  <td class="py-3 px-4 text-right align-middle tabular-nums text-gray-500">
                    <%= row[:rate] ? fmt_money(row[:rate]) : "-" %>
                  </td>
                <% end %>
                <td class="py-3 px-4 text-right align-middle tabular-nums font-semibold text-gray-700">
                  <%= fmt_hours(row[:hours]) %><span class="text-xs font-normal text-gray-400">h</span>
                </td>
                <% if @has_any_rate %>
                  <td class="py-3 px-5 text-right align-middle tabular-nums font-semibold text-gray-700">
                    <%= row[:value] ? fmt_money(row[:value]) : "-" %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="bg-gray-50/70 border-t border-gray-200">
              <td class="py-3 px-5 text-gray-400 text-xs uppercase tracking-wide">Total</td>
              <td class="py-3 px-4 text-right tabular-nums text-gray-500"><%= @working_days %></td>
              <% if @has_any_rate %><td></td><% end %>
              <td class="py-3 px-4 text-right tabular-nums text-gray-900 font-semibold">
                <%= fmt_hours(@total_hours) %><span class="text-xs font-normal text-gray-400">h</span>
              </td>
              <% if @has_any_rate %>
                <td class="py-3 px-5 text-right tabular-nums text-gray-900 font-semibold">
                  <%= @total_value > 0 ? fmt_money(@total_value) : "-" %>
                </td>
              <% end %>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  <% end %>
</section>
