---
export const prerender = false

import Layout from "../../layouts/Layout.astro"
import { db } from "../../db"
import { projects, timeEntries } from "../../db/schema"
import { and, eq, gte, lte, sql } from "drizzle-orm"
import { auth } from "../../lib/auth"

const session = await auth.api.getSession({ headers: Astro.request.headers })
if (!session) return Astro.redirect("/login")
const userId = session.user.id

// --- month helpers ---
const pad = (n: number) => String(n).padStart(2, "0")
const fmtDate = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`
const monthKey = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}`

const now = new Date()
const monthParam = Astro.url.searchParams.get("month")
const parsed = monthParam && /^\d{4}-\d{2}$/.test(monthParam) ? monthParam.split("-").map(Number) : null
const year = parsed ? parsed[0] : now.getFullYear()
const month = parsed ? parsed[1] : now.getMonth() + 1 // 1-12

const first = new Date(year, month - 1, 1)
const last = new Date(year, month, 0) // day 0 of next month = last day of this month
const startStr = fmtDate(first)
const endStr = fmtDate(last)

const prevMonth = monthKey(new Date(year, month - 2, 1))
const nextMonth = monthKey(new Date(year, month, 1))
const thisMonth = monthKey(now)
const currentMonth = monthKey(first)

const monthLabelFull = new Intl.DateTimeFormat("en-US", { month: "long", year: "numeric" }).format(first)
const offset = (year - now.getFullYear()) * 12 + (month - 1 - now.getMonth())
const monthLabel =
  offset === 0 ? "This month" : offset === -1 ? "Last month" : offset === 1 ? "Next month" : monthLabelFull

// --- data: total hours per project for the month ---
const rows = await db
  .select({
    name: projects.name,
    hourlyRate: projects.hourlyRate,
    hours: sql<number>`sum(${timeEntries.hours})`,
    days: sql<number>`count(*)`,
  })
  .from(timeEntries)
  .innerJoin(projects, eq(timeEntries.projectId, projects.id))
  .where(and(eq(timeEntries.userId, userId), gte(timeEntries.date, startStr), lte(timeEntries.date, endStr)))
  .groupBy(timeEntries.projectId, projects.name, projects.hourlyRate)
  .orderBy(projects.name)

const report = rows.map((r) => {
  const hours = Number(r.hours) || 0
  return {
    name: r.name,
    hours,
    days: Number(r.days) || 0,
    rate: r.hourlyRate ?? null,
    value: r.hourlyRate ? hours * r.hourlyRate : null,
  }
})

// Distinct days worked across all projects (a day can hold more than one project).
const [{ n: workingDaysRaw } = { n: 0 }] = await db
  .select({ n: sql<number>`count(distinct ${timeEntries.date})` })
  .from(timeEntries)
  .where(and(eq(timeEntries.userId, userId), gte(timeEntries.date, startStr), lte(timeEntries.date, endStr)))
const workingDays = Number(workingDaysRaw) || 0

const totalHours = report.reduce((s, r) => s + r.hours, 0)
const totalValue = report.reduce((s, r) => s + (r.value ?? 0), 0)
const hasAnyRate = report.some((r) => (r.rate ?? 0) > 0)

// --- formatting (mirrors the weekly view) ---
const fmtH = (h: number) => (Number.isInteger(h) ? String(h) : h.toFixed(1))
const fmtM = (v: number) =>
  new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", minimumFractionDigits: 0, maximumFractionDigits: 2 }).format(v)
---

<Layout title="Monthly report · Flavio Antelo" description="Monthly timesheet report." noindex={true} footer={false} wide={true}>
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-24" style="font-feature-settings: 'cv02' 1, 'tnum' 1;">
    {/* Back link */}
    <div class="flex items-center justify-between gap-3 mb-6 text-xs text-gray-400">
      <a href="/timesheet" class="inline-flex items-center gap-1.5 hover:text-gray-900 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to timesheet
      </a>
      <span class="truncate max-w-[16rem]">{session.user.email}</span>
    </div>

    {/* Header */}
    <div class="flex items-end justify-between flex-wrap gap-6 mb-8">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight text-gray-900">Monthly report</h1>
        <p class="text-sm text-gray-500 mt-1">Total hours per project</p>
      </div>
      <div class="text-right">
        <div class="text-3xl font-semibold tabular-nums text-gray-900 leading-none">
          {fmtH(totalHours)}<span class="text-base font-normal text-gray-400 ml-0.5">h</span>
        </div>
        <div class={`text-sm font-medium text-gray-500 tabular-nums mt-1.5 ${totalValue > 0 ? "" : "invisible"}`}>
          {totalValue > 0 ? fmtM(totalValue) : "—"}
        </div>
        <div class="text-xs text-gray-400 mt-1 uppercase tracking-wide">{monthLabelFull.toLowerCase()}</div>
      </div>
    </div>

    {/* Month navigation */}
    <div class="flex items-center gap-2 mb-4">
      <div class="inline-flex items-center h-9 rounded-lg border border-gray-300 overflow-hidden divide-x divide-gray-300">
        <a
          href={`/timesheet/report?month=${prevMonth}`}
          class="w-9 h-full inline-flex items-center justify-center text-lg text-gray-500 hover:bg-gray-50 transition-colors"
          aria-label="Previous month"
        >‹</a>
        <a
          href={`/timesheet/report?month=${nextMonth}`}
          class="w-9 h-full inline-flex items-center justify-center text-lg text-gray-500 hover:bg-gray-50 transition-colors"
          aria-label="Next month"
        >›</a>
      </div>
      <div class="inline-flex items-center h-9 px-4 rounded-lg border border-gray-300 bg-white text-sm text-gray-700">
        <span class="font-medium tabular-nums">{monthLabel}</span>
      </div>
      {currentMonth !== thisMonth && (
        <a
          href="/timesheet/report"
          class="h-9 px-3 inline-flex items-center rounded-lg border border-gray-300 bg-white text-sm text-gray-600 hover:bg-gray-50 transition-colors"
        >This month</a>
      )}
    </div>

    {/* Table */}
    {report.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-200 bg-gray-50/50 py-20 text-center">
        <p class="text-sm text-gray-500">No hours logged in {monthLabelFull}.</p>
        <p class="text-xs text-gray-400 mt-1">Log some time on the timesheet to see it here.</p>
      </div>
    ) : (
      <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-gray-50/70 border-b border-gray-200">
                <th class="text-left font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-5 min-w-[150px]">Project</th>
                <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-4 w-20">Days</th>
                {hasAnyRate && (
                  <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-4 w-24">Rate</th>
                )}
                <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-4 w-24">Hours</th>
                {hasAnyRate && (
                  <th class="text-right font-medium text-gray-400 text-xs uppercase tracking-wide py-3 px-5 w-28">Value</th>
                )}
              </tr>
            </thead>
            <tbody>
              {report.map((r) => (
                <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50/60 transition-colors">
                  <td class="py-3 px-5 align-middle whitespace-nowrap text-gray-900 font-medium">{r.name}</td>
                  <td class="py-3 px-4 text-right align-middle tabular-nums text-gray-500">{r.days}</td>
                  {hasAnyRate && (
                    <td class="py-3 px-4 text-right align-middle tabular-nums text-gray-500">
                      {r.rate ? fmtM(r.rate) : "—"}
                    </td>
                  )}
                  <td class="py-3 px-4 text-right align-middle tabular-nums font-semibold text-gray-700">
                    {fmtH(r.hours)}<span class="text-xs font-normal text-gray-400">h</span>
                  </td>
                  {hasAnyRate && (
                    <td class="py-3 px-5 text-right align-middle tabular-nums font-semibold text-gray-700">
                      {r.value != null ? fmtM(r.value) : "—"}
                    </td>
                  )}
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr class="bg-gray-50/70 border-t border-gray-200">
                <td class="py-3 px-5 text-gray-400 text-xs uppercase tracking-wide">Total</td>
                <td class="py-3 px-4 text-right tabular-nums text-gray-500">{workingDays}</td>
                {hasAnyRate && <td />}
                <td class="py-3 px-4 text-right tabular-nums text-gray-900 font-semibold">
                  {fmtH(totalHours)}<span class="text-xs font-normal text-gray-400">h</span>
                </td>
                {hasAnyRate && (
                  <td class="py-3 px-5 text-right tabular-nums text-gray-900 font-semibold">
                    {totalValue > 0 ? fmtM(totalValue) : "—"}
                  </td>
                )}
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    )}
  </section>
</Layout>
