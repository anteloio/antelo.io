---
export const prerender = false

import Layout from "../layouts/Layout.astro"
import { actions } from "astro:actions"
import { db } from "../db"
import { tweets as tweetTable } from "../db/schema"

const all = await db.select().from(tweetTable)

// Queued first (by scheduled time), then sent ones at the bottom (most recent first).
const sorted = all.sort((a, b) => {
  const aSent = !!a.sentAt
  const bSent = !!b.sentAt
  if (aSent !== bSent) return aSent ? 1 : -1
  if (aSent) return (b.sentAt ?? "").localeCompare(a.sentAt ?? "")
  return a.scheduledAt.localeCompare(b.scheduledAt)
})

const queuedCount = all.filter((t) => !t.sentAt).length

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  weekday: "short",
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
})

const intentUrl = (text: string) => `https://x.com/intent/tweet?text=${encodeURIComponent(text)}`
---

<Layout title="Queue · Flavio Antelo" description="Tweet queue." noindex={true}>
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Tweet queue</h1>
    <p class="text-gray-500 mb-16">
      {queuedCount} queued. Click <span class="font-medium text-gray-700">Post on X</span> to open the composer, then <span
        class="font-medium text-gray-700">Mark as sent</span
      > once it's live.
    </p>

    {
      sorted.length === 0 ? (
        <div class="text-center py-20 text-gray-400">
          <p class="text-sm">Queue is empty.</p>
        </div>
      ) : (
        <div class="grid gap-6">
          {sorted.map((tweet) => {
            const count = [...tweet.text].length
            const over = count > 280
            const sent = !!tweet.sentAt
            const isPast = !sent && new Date(tweet.scheduledAt).valueOf() < Date.now()
            return (
              <article
                class:list={[
                  "rounded-2xl border p-5 transition-colors",
                  sent ? "border-gray-100 bg-gray-50 opacity-60" : "border-gray-200 bg-white",
                ]}
              >
                <div class="flex items-center justify-between mb-3">
                  <p class="text-xs font-medium text-gray-400">
                    {dateFormatter.format(new Date(tweet.scheduledAt))}
                    {sent && <span class="ml-2 text-green-600">· sent</span>}
                    {isPast && <span class="ml-2 text-amber-500">· past</span>}
                  </p>
                  <span class:list={["text-xs tabular-nums", over ? "text-red-500 font-semibold" : "text-gray-400"]}>
                    {count}/280
                  </span>
                </div>

                <p
                  class:list={[
                    "text-[15px] leading-relaxed whitespace-pre-line mb-4",
                    sent ? "text-gray-400 line-through decoration-gray-300" : "text-gray-900",
                  ]}
                >
                  {tweet.text}
                </p>

                <div class="flex items-center gap-3">
                  {!sent && (
                    <a
                      href={intentUrl(tweet.text)}
                      class="inline-flex items-center gap-2 text-sm bg-black text-white px-4 py-1.5 rounded-full hover:bg-gray-800 transition-colors"
                    >
                      Post on X<span aria-hidden="true">→</span>
                    </a>
                  )}
                  <form method="POST" action={actions.toggleSent}>
                    <input type="hidden" name="id" value={tweet.id} />
                    <input type="hidden" name="sent" value={sent ? "" : "true"} />
                    <button
                      type="submit"
                      class:list={[
                        "text-sm px-4 py-1.5 rounded-full border transition-colors",
                        sent
                          ? "border-gray-200 text-gray-500 hover:bg-gray-100"
                          : "border-gray-300 text-gray-700 hover:bg-gray-50",
                      ]}
                    >
                      {sent ? "Undo" : "Mark as sent"}
                    </button>
                  </form>
                </div>
              </article>
            )
          })}
        </div>
      )
    }
  </section>
</Layout>
