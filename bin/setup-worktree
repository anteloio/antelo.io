#!/usr/bin/env bash
#
# Bootstrap a freshly created Conductor worktree:
#   1. Link this worktree's gitignored .envrc to the canonical one in the repo
#      root, so the TURSO + Google OAuth secrets live in one place per machine.
#   2. Copy the Rails master key from the main checkout (gitignored, one per
#      machine) and install dependencies.
#
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Conductor sets CONDUCTOR_ROOT_PATH to the main checkout; fall back to the
# first entry of `git worktree list` (git always lists the main worktree first).
main_root="${CONDUCTOR_ROOT_PATH:-$(git worktree list --porcelain | sed -n '1s/^worktree //p')}"

# 1. Link the shared secrets file (the repo root always has one).
ln -sfn "$main_root/.envrc" "$repo_root/.envrc"
direnv allow "$repo_root"
echo "setup-worktree: linked .envrc -> $main_root/.envrc"

# 2. Master key + dependencies.
if [ ! -f "$repo_root/config/master.key" ] && [ -f "$main_root/config/master.key" ]; then
  cp "$main_root/config/master.key" "$repo_root/config/master.key"
  echo "setup-worktree: copied config/master.key from main checkout"
fi

(cd "$repo_root" && bundle install)
