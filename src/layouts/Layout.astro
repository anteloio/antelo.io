---
interface Props {
  title: string
  description?: string
  noindex?: boolean
  footer?: boolean
  wide?: boolean
}

const {
  title,
  description = "Flavio Antelo · Freelance engineer building custom apps and AI automations for small and medium businesses.",
  noindex = false,
  footer = true,
  wide = false,
} = Astro.props

const container = wide ? "max-w-5xl" : "max-w-3xl"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <header class="border-b border-gray-100">
      <nav class={`${container} mx-auto px-6 py-4 flex items-center justify-between`}>
        <a
          href="/"
          class="inline-flex items-baseline text-base font-semibold lowercase tracking-[0.18em] text-gray-900 hover:text-gray-600 transition-colors"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          antel<span
            class="inline-block w-[0.62em] h-[0.62em] rounded-full ml-[0.04em]"
            style="background: radial-gradient(circle at 35% 28%, #ff7a7a 0%, #e23b3b 52%, #b81f1f 100%); box-shadow: inset 0 -0.06em 0.12em rgba(0,0,0,0.28); transform: translateY(0.02em);"
            aria-hidden="true"></span><span class="sr-only">antelo</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="/blog" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Posts</a>
          <a
            href="https://wa.me/33766884815"
            class="text-sm bg-black text-white px-4 py-1.5 rounded-full hover:bg-gray-800 transition-colors"
          >
            Hire me
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    {
      footer && (
        <footer class="border-t border-gray-100 mt-24">
          <div class="max-w-3xl mx-auto px-6 py-8 flex items-center justify-between">
            <p class="text-sm text-gray-400">© 2025 Flavio Antelo</p>
            <div class="flex items-center gap-4">
              <a
                href="https://x.com/anteloio"
                class="text-sm text-gray-400 hover:text-gray-900 transition-colors"
              >
                X
              </a>
              <a
                href="https://github.com/anteloio"
                class="text-sm text-gray-400 hover:text-gray-900 transition-colors"
              >
                GitHub
              </a>
            </div>
          </div>
        </footer>
      )
    }
  </body>
</html>
