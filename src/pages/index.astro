---
import Layout from "../layouts/Layout.astro"

const projects = [
  {
    name: "Kali Care",
    url: "https://kali.care",
    description: "Healthcare coordination platform for care plans, patients, encounters, and messaging.",
    tags: ["Rails", "React", "Postgres"],
    image: "/work/kali-care.png",
  },
  {
    name: "Playlib",
    url: "https://playlib.fr",
    description: "Online booking platform for padel, tennis and racket sports clubs.",
    tags: ["Rails", "React", "Postgres"],
    image: "/work/playlib.png",
  },
  {
    name: "Immobilier",
    url: "https://immobilier.com.br",
    description: "Real estate platform for the Brazilian market.",
    tags: ["Rails", "React", "SQLite"],
    image: "/work/immobilier.png",
  },
  {
    name: "Reserva Ink",
    url: "https://reservaink.com.br",
    description: "Booking platform for tattoo studios across Brazil.",
    tags: ["Rails", "React", "Postgres", "Redis"],
    image: "/work/reserva-ink.png",
  },
  {
    name: "Timesheet",
    url: "/timesheet",
    description: "Internal tool to log hours worked per project, week by week.",
    tags: ["Astro", "Turso", "Drizzle"],
    image: "/work/timesheet.png",
  },
]
---

<Layout title="Flavio Antelo · Freelance Engineer">
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
    <div class="flex items-start gap-6 mb-10">
      <img src="/avatar.jpg" alt="Flavio Antelo" class="w-16 h-16 rounded-full object-cover flex-shrink-0" />
      <div>
        <h1 class="text-2xl font-semibold text-gray-900 mb-1">Flavio Antelo</h1>
        <p class="text-gray-500 text-sm">Brazil · Based in France</p>
      </div>
    </div>

    <p class="text-xl text-gray-800 leading-relaxed mb-4 max-w-xl">
      Ex-developer turned entrepreneur. I build agent loops and software systems that run businesses.
    </p>
    <p class="text-gray-500 leading-relaxed mb-10 max-w-xl">
      Available for freelance projects, from product architecture to full-stack implementation and AI integrations.
    </p>

    <!-- Rate + CTA -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <a
        href="https://wa.me/33766884815"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-black text-white text-sm font-medium px-5 py-2.5 rounded-full hover:bg-gray-800 transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        Send me a message
      </a>
      <div class="text-sm text-gray-500">
        <span class="font-medium text-gray-900">€960</span> / day &nbsp;·&nbsp;
        <span class="font-medium text-gray-900">€120</span> / hour
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="max-w-3xl mx-auto px-6 pb-16">
    <h2 class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-6">Things I've shipped</h2>
    <div class="grid gap-3">
      {
        projects.map((project) => (
          <a
            href={project.url}
            target={project.url.startsWith("http") ? "_blank" : undefined}
            rel={project.url.startsWith("http") ? "noopener noreferrer" : undefined}
            class="group flex items-center gap-4 p-4 border border-gray-100 rounded-xl hover:border-gray-300 transition-colors"
          >
            {project.image && (
              <div class="w-1/3 flex-shrink-0 aspect-[4/3] rounded-lg overflow-hidden bg-gray-50 border border-gray-100">
                <img
                  src={project.image}
                  alt={`${project.name} screenshot`}
                  loading="lazy"
                  class="w-full h-full object-cover object-top"
                />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="text-sm font-medium text-gray-900">{project.name}</h3>
                <svg
                  class="w-3 h-3 text-gray-300 group-hover:text-gray-500 transition-colors flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  {project.url.startsWith("http") ? (
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 17L17 7M17 7H7M17 7v10"
                    />
                  ) : (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 6l6 6-6 6" />
                  )}
                </svg>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed mb-3">{project.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="text-xs text-gray-400 bg-gray-50 px-2 py-0.5 rounded-full whitespace-nowrap">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- About -->
  <section class="max-w-3xl mx-auto px-6 pb-16">
    <h2 class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-6">A bit about me</h2>
    <div class="prose prose-sm text-gray-600 leading-relaxed space-y-4 max-w-xl">
      <p>
        I first built for the web back in '99, when Dreamweaver 3 had just launched, and I've been writing Ruby on Rails
        since 2011. Along the way I shipped products across healthcare, real estate, and e-commerce, and over time I
        became more interested in the systems that run businesses than in the code itself.
      </p>
      <p>
        Today I help companies ship faster. I design architecture, build full-stack features, and integrate AI agents
        into real workflows.
      </p>
      <p>Based in France, working globally. Available for both short engagements and longer-term collaborations.</p>
    </div>
  </section>
</Layout>
