---
export const prerender = false

import Layout from "../layouts/Layout.astro"
import { Timesheet } from "../components/Timesheet"
import { db } from "../db"
import { projects, timeEntries, locations, dayLocations } from "../db/schema"
import { and, eq, gte, lte, sql } from "drizzle-orm"
import { auth } from "../lib/auth"

const session = await auth.api.getSession({ headers: Astro.request.headers })
if (!session) return Astro.redirect("/login")
const userId = session.user.id

// --- date helpers (local, Monday-based week) ---
const pad = (n: number) => String(n).padStart(2, "0")
const fmt = (d: Date) => `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`
const addDays = (d: Date, n: number) => { const x = new Date(d); x.setDate(x.getDate() + n); return x }
const mondayOf = (d: Date) => { const x = new Date(d); x.setHours(0, 0, 0, 0); return addDays(x, -((x.getDay() + 6) % 7)) }

// --- week range ---
const startParam = Astro.url.searchParams.get("start")
const weekStart = mondayOf(startParam ? new Date(startParam + "T00:00:00") : new Date())
const weekDates = Array.from({ length: 7 }, (_, i) => addDays(weekStart, i))
const startStr = fmt(weekStart)
const endStr = fmt(weekDates[6])
const todayStr = fmt(new Date())
const prevStart = fmt(addDays(weekStart, -7))
const nextStart = fmt(addDays(weekStart, 7))
const thisStart = fmt(mondayOf(new Date()))

const weekOffset = Math.round((weekStart.getTime() - mondayOf(new Date()).getTime()) / (7 * 86400000))
const monthDay = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric" })
const withYear = (d: Date) => d.getFullYear() === new Date().getFullYear() ? monthDay.format(d) : `${monthDay.format(d)}, ${d.getFullYear()}`
const weekLabel = weekOffset === 0 ? "This week" : weekOffset === -1 ? "Last week" : weekOffset === 1 ? "Next week" : `${withYear(weekStart)} - ${withYear(weekDates[6])}`

// --- data ---
const allProjects = await db.select().from(projects).where(eq(projects.userId, userId)).orderBy(projects.name)
const entries = await db
  .select({ projectId: timeEntries.projectId, date: timeEntries.date, hours: timeEntries.hours })
  .from(timeEntries)
  .where(and(eq(timeEntries.userId, userId), gte(timeEntries.date, startStr), lte(timeEntries.date, endStr)))

const counts = await db
  .select({ projectId: timeEntries.projectId, n: sql<number>`count(*)` })
  .from(timeEntries).where(eq(timeEntries.userId, userId)).groupBy(timeEntries.projectId)
const entryCounts: Record<string, number> = {}
for (const c of counts) entryCounts[String(c.projectId)] = Number(c.n)

const allLocations = await db.select().from(locations).where(eq(locations.userId, userId)).orderBy(locations.name)
const dayLocs = await db
  .select({ date: dayLocations.date, locationId: dayLocations.locationId })
  .from(dayLocations)
  .where(and(eq(dayLocations.userId, userId), gte(dayLocations.date, startStr), lte(dayLocations.date, endStr)))

const locCounts = await db
  .select({ locationId: dayLocations.locationId, n: sql<number>`count(*)` })
  .from(dayLocations).where(eq(dayLocations.userId, userId)).groupBy(dayLocations.locationId)
const locationCounts: Record<string, number> = {}
for (const c of locCounts) locationCounts[String(c.locationId)] = Number(c.n)
---

<Layout title="Timesheet · Flavio Antelo" description="Timesheet." noindex={true} footer={false} wide={true}>
  <Timesheet
    client:load
    weekDates={weekDates.map(fmt)}
    startStr={startStr}
    todayStr={todayStr}
    prevStart={prevStart}
    nextStart={nextStart}
    thisStart={thisStart}
    weekLabel={weekLabel}
    userEmail={session.user.email}
    projects={allProjects.map((p) => ({ id: p.id!, name: p.name, hourlyRate: p.hourlyRate ?? null }))}
    entries={entries}
    entryCounts={entryCounts}
    locations={allLocations.map((l) => ({ id: l.id!, name: l.name }))}
    dayLocations={dayLocs}
    locationCounts={locationCounts}
  />

  <style is:global>
    dialog[open] {
      animation: dialog-pop 0.16s ease-out;
    }
    dialog::backdrop {
      animation: dialog-fade 0.16s ease-out;
    }
    @keyframes dialog-pop {
      from { opacity: 0; transform: translateY(6px) scale(0.97); }
      to   { opacity: 1; transform: none; }
    }
    @keyframes dialog-fade {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
  </style>
</Layout>
