---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title="Posts · Flavio Antelo" description="Thoughts on software, agent loops, and building businesses.">
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Posts</h1>
    <p class="text-gray-500 mb-16">Thoughts on software, agent loops, and building businesses.</p>

    {posts.length === 0 ? (
      <div class="text-center py-20 text-gray-400">
        <p class="text-sm">Posts coming soon.</p>
      </div>
    ) : (
      <div class="grid gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block">
            <p class="text-xs text-gray-400 mb-1">{dateFormatter.format(post.data.publishedAt)}</p>
            <h2 class="text-lg font-medium text-gray-900 group-hover:text-gray-600 transition-colors mb-1">
              {post.data.title}
            </h2>
            <p class="text-sm text-gray-500 leading-relaxed">{post.data.description}</p>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
